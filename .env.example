# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=storageuser
DB_PASSWORD=storagepass
DB_NAME=storagedb
DB_SSLMODE=disable

STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=documents
STORAGE_USE_SSL=false

# IMPORTANT: Change in production — openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24

# Presigned URL TTL — set higher for backend consumers (60 = 1 hour)
PRESIGNED_URL_MINUTES=60

DEFAULT_QUOTA_BYTES=10737418240

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
WORKER_CONCURRENCY=10

# Watchdog: mark documents failed after this many minutes stuck in "processing"
PROCESSING_TIMEOUT_MINUTES=30

# Rate limit: max PDF uploads per user per minute (0 = disabled)
RATE_LIMIT_UPLOADS_PER_MINUTE=10

GIN_MODE=debug
